# ============================================================
# APEX V3 — Phase 12: MT5 Demo Validation Environment
# ============================================================
# Copy this file to infrastructure/docker/.env before running Phase 12.
# NEVER commit credentials to version control.

# ============================================================
# MT5 BRIDGE — Windows host running mt5_bridge.py
# ============================================================
# On macOS: host.docker.internal resolves to the macOS host
# If your Windows MT5 host is a separate machine, replace with its IP.
MT5_BRIDGE_URL=http://host.docker.internal:8000

# MT5 Demo Account Credentials (MetaQuotes-Demo $5,000 account)
MT5_LOGIN=5052293921
MT5_PASSWORD=GoPcL!F8
MT5_SERVER=MetaQuotes-Demo

# ============================================================
# POSTGRESQL
# ============================================================
DB_PASSWORD=apex_phase12_demo_2026
DATABASE_URL=postgres://apex:apex_phase12_demo_2026@localhost:5432/apex_v3
POSTGRES_URL=postgres://apex:apex_phase12_demo_2026@localhost:5432/apex_v3
POSTGRES_USER=apex
POSTGRES_DB=apex_v3

# ============================================================
# REDIS
# ============================================================
