# ============================================
# APEX V3 Infrastructure Configuration
# ============================================

# Copy this file to .env and fill in your values

# ---------------- Database ----------------
DB_PASSWORD=your_secure_password_here

# ---------------- AI Providers ----------------
# At least one AI provider is required for AI Council
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# ---------------- Trading ----------------
MT5_BRIDGE_URL=http://host.docker.internal:5555
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
TRADING_MODE=demo
SHADOW_MODE=true

# ---------------- Monitoring ----------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_in_production

# ---------------- Feature Flags ----------------
ENABLE_AI_VALIDATION=true
ENABLE_AUTO_TRADING=false
LOG_LEVEL=info
